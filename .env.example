# Server
PORT=4000

# Admin JWT secret — change this in production
JWT_SECRET=change-this-to-a-long-random-string

# Pesapal API credentials
# Get these from https://developer.pesapal.com
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=

# "sandbox" for testing (cybqa.pesapal.com), "live" for production (pay.pesapal.com)
PESAPAL_ENV=sandbox

# Must be publicly accessible URLs (use ngrok or similar for local development)
# IPN: backend endpoint that receives Pesapal payment status notifications
PESAPAL_IPN_URL=https://yourdomain.com/api/payments/ipn
# Callback: frontend page where Pesapal redirects the user after payment
# Pesapal appends ?OrderTrackingId=...&OrderMerchantReference=... automatically
PESAPAL_CALLBACK_URL=https://yourdomain.com/payment/status

# IPN ID from Pesapal dashboard (optional — auto-registered if not set)
PESAPAL_IPN_ID=

# Email notifications via Resend (https://resend.com — free tier: 100 emails/day)
# 1. Sign up at resend.com (~1 minute, no credit card)
# 2. Create an API key at resend.com/api-keys → paste here
# 3. Where payment-received emails should be sent
RESEND_API_KEY=
ADMIN_EMAIL=admin@example.com
# From-address. Use the default while testing; switch to your own domain after verifying it in Resend
NOTIFICATION_FROM=Wangaré Luxe <onboarding@resend.dev>
