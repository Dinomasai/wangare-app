# Server
PORT=4000

# Admin JWT secret — change this in production
JWT_SECRET=change-this-to-a-long-random-string

# Pesapal API credentials
# Get these from https://developer.pesapal.com
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=

# "sandbox" for testing (cybqa.pesapal.com), "live" for production (pay.pesapal.com)
PESAPAL_ENV=sandbox

# Must be a publicly accessible URL (use ngrok or similar for local development)
PESAPAL_IPN_URL=https://yourdomain.com/api/payments/ipn
PESAPAL_CALLBACK_URL=https://yourdomain.com/api/payments/callback

# IPN ID from Pesapal dashboard (optional — auto-registered if not set)
PESAPAL_IPN_ID=
